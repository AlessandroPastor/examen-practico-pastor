<!-- Regla de detección de fuerza bruta SSH -->
<!-- Se activa cuando una misma IP genera 10 o más fallos -->
<!-- de autenticación SSH en un intervalo de 60 segundos -->
<group name="local,ssh,">

  <!-- Regla padre: detecta un solo fallo SSH (referencia al SID 5716 de Wazuh) -->
  <rule id="100001" level="10" frequency="10" timeframe="60">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip />
    <description>Ataque de fuerza bruta SSH detectado desde $(srcip)</description>
    <group>authentication_failures,brute_force</group>
  </rule>

</group>
